# ========================
# SERVER
# ========================
YOURAPP_SERVER__PORT=8080
YOURAPP_SERVER__READ_TIMEOUT=30
YOURAPP_SERVER__WRITE_TIMEOUT=30
YOURAPP_SERVER__IDLE_TIMEOUT=120
YOURAPP_SERVER__CORS_ALLOWED_ORIGINS=http://localhost:3000

# ========================
# DATABASE
# ========================
YOURAPP_DATABASE__HOST=localhost
YOURAPP_DATABASE__PORT=5432
YOURAPP_DATABASE__USER=postgres
YOURAPP_DATABASE__PASSWORD=
YOURAPP_DATABASE__NAME=myapp
YOURAPP_DATABASE__SSL_MODE=disable
YOURAPP_DATABASE__MAX_OPEN_CONNS=25
YOURAPP_DATABASE__MAX_IDLE_CONNS=5
YOURAPP_DATABASE__CONN_MAX_LIFETIME=15m
YOURAPP_DATABASE__CONN_MAX_IDLE_TIME=5m



# ========================
# AUTH
# ========================
YOURAPP_AUTH__ACCESS_SECRET=change-me-to-a-long-random-secret
YOURAPP_AUTH__REFRESH_SECRET=change-me-to-another-long-random-secret
YOURAPP_AUTH__ACCESS_TOKEN_EXPIRY=15m
YOURAPP_AUTH__REFRESH_TOKEN_EXPIRY=168h

# ========================
# LOGGER
# ========================
YOURAPP_LOGGER__LEVEL=debug
YOURAPP_LOGGER__PRETTY=true
